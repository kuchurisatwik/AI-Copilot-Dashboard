# ==============================================
# Trader Copilot AI — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Application
APP_NAME=Trader Copilot AI
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trader_copilot
DATABASE_ECHO=false

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Binance API (no key needed for public endpoints)
BINANCE_BASE_URL=https://api.binance.com

# Screenshot Storage
SCREENSHOT_STORAGE_PATH=./screenshots
MAX_SCREENSHOT_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
